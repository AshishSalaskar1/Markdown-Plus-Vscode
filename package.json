{
  "name": "markdown-plus",
  "displayName": "Markdown Plus",
  "description": "WYSIWYG markdown editor for VS Code, inspired by Obsidian",
  "version": "0.1.0",
  "publisher": "markdown-plus",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "customEditors": [
      {
        "viewType": "markdownPlus.editor",
        "displayName": "Markdown Plus",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.markdown"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "markdownPlus.openEditor",
        "title": "Open with Markdown Plus"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "markdownPlus.openEditor",
          "when": "resourceLangId == markdown"
        }
      ],
      "editor/title/context": [
        {
          "command": "markdownPlus.openEditor",
          "when": "resourceLangId == markdown"
        }
      ],
      "commandPalette": [
        {
          "command": "markdownPlus.openEditor"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "vscode:prepublish": "node esbuild.config.mjs --production",
    "package": "npx @vscode/vsce package"
  },
  "dependencies": {
    "@milkdown/core": "^7.18.0",
    "@milkdown/crepe": "^7.18.0",
    "@milkdown/ctx": "^7.18.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
