{
  "name": "markdown-pro",
  "displayName": "Markdown Pro",
  "description": "WYSIWYG markdown editor for VS Code",
  "version": "0.2.0",
  "publisher": "ashishsalaskar",
  "icon": "Markdown_Plus_Logo_v2.png",
  "license": "MIT",
  "keywords": [
    "markdown",
    "wysiwyg",
    "editor",
    "milkdown",
    "rich-text",
    "preview",
    "formatting"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ashish/markdown-plus"
  },
  "homepage": "https://github.com/ashish/markdown-plus#readme",
  "bugs": {
    "url": "https://github.com/ashish/markdown-plus/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "pricing": "Free",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "customEditors": [
      {
        "viewType": "markdownPro.editor",
        "displayName": "Markdown Pro",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.markdown"
          }
        ],
        "priority": "option"
      }
    ],
    "keybindings": [
      {
        "command": "markdownPro.openEditor",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "resourceLangId == markdown"
      }
    ],
    "commands": [
      {
        "command": "markdownPro.openEditor",
        "title": "Open Editor",
        "category": "Markdown Pro",
        "icon": "$(book)"
      },
      {
        "command": "markdownPro.changeTheme",
        "title": "Change Theme",
        "category": "Markdown Pro"
      },
      {
        "command": "markdownPro.increaseFontSize",
        "title": "Increase Font Size",
        "category": "Markdown Pro"
      },
      {
        "command": "markdownPro.decreaseFontSize",
        "title": "Decrease Font Size",
        "category": "Markdown Pro"
      },
      {
        "command": "markdownPro.resetFontSize",
        "title": "Reset Font Size",
        "category": "Markdown Pro"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "markdownPro.openEditor",
          "when": "resourceLangId == markdown"
        }
      ],
      "editor/title": [
        {
          "command": "markdownPro.openEditor",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "markdownPro.openEditor",
          "when": "resourceLangId == markdown"
        }
      ],
      "commandPalette": [
        {
          "command": "markdownPro.openEditor"
        },
        {
          "command": "markdownPro.changeTheme"
        },
        {
          "command": "markdownPro.increaseFontSize"
        },
        {
          "command": "markdownPro.decreaseFontSize"
        },
        {
          "command": "markdownPro.resetFontSize"
        }
      ]
    },
    "configuration": {
      "title": "Markdown Pro",
      "properties": {
        "markdownPro.theme": {
          "type": "string",
          "default": "vscode",
          "enum": [
            "vscode",
            "github-light",
            "github-dark",
            "dracula",
            "nord",
            "solarized-light",
            "solarized-dark",
            "one-dark",
            "tokyo-night",
            "gruvbox-light",
            "gruvbox-dark"
          ],
          "enumItemLabels": [
            "VS Code (match editor theme)",
            "GitHub Light",
            "GitHub Dark",
            "Dracula",
            "Nord",
            "Solarized Light",
            "Solarized Dark",
            "One Dark",
            "Tokyo Night",
            "Gruvbox Light",
            "Gruvbox Dark"
          ],
          "markdownDescription": "Color theme for the Markdown Pro WYSIWYG editor. Select `VS Code` to inherit your current editor theme, or choose a standalone theme."
        },
        "markdownPro.fontSize": {
          "type": "number",
          "default": 16,
          "minimum": 8,
          "maximum": 40,
          "markdownDescription": "Font size (in pixels) for the Markdown Pro editor. Use the commands `Markdown Pro: Increase Font Size` / `Decrease Font Size` for quick adjustments."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "vscode:prepublish": "node esbuild.config.mjs --production",
    "package": "npx @vscode/vsce package"
  },
  "dependencies": {
    "@milkdown/core": "^7.18.0",
    "@milkdown/crepe": "^7.18.0",
    "@milkdown/ctx": "^7.18.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
