{
  "name": "markdown-pro",
  "displayName": "Markdown Pro",
  "description": "WYSIWYG markdown editor for VS Code",
  "version": "0.8.3",
  "publisher": "ashishsalaskar",
  "icon": "Markdown_Plus_Logo_v2.png",
  "license": "MIT",
  "keywords": [
    "markdown",
    "wysiwyg",
    "editor",
    "milkdown",
    "rich-text",
    "preview",
    "formatting"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AshishSalaskar1/Markdown-Plus-Vscode"
  },
  "homepage": "https://github.com/AshishSalaskar1/Markdown-Plus-Vscode#readme",
  "bugs": {
    "url": "https://github.com/AshishSalaskar1/Markdown-Plus-Vscode/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "pricing": "Free",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "customEditors": [
      {
        "viewType": "markdownPro.editor",
        "displayName": "Markdown Pro",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.*.md"
          },
          {
            "filenamePattern": "*.*.*.md"
          },
          {
            "filenamePattern": "*.*.*.*.md"
          },
          {
            "filenamePattern": "*.markdown"
          },
          {
            "filenamePattern": "*.instructions.md"
          },
          {
            "filenamePattern": "*.copilotmd"
          }
        ],
        "priority": "option"
      }
    ],
    "keybindings": [
      {
        "command": "markdownPro.openEditor",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "resourceLangId =~ /^(markdown|prompt|instructions|chatagent|skill)$/"
      },
      {
        "command": "markdownPro.search",
        "key": "ctrl+f",
        "mac": "cmd+f",
        "when": "activeCustomEditorId == 'markdownPro.editor'"
      }
    ],
    "commands": [
      {
        "command": "markdownPro.openEditor",
        "title": "Open with Markdown Pro",
        "category": "Markdown Pro",
        "icon": "$(book)"
      },
      {
        "command": "markdownPro.changeTheme",
        "title": "Change Theme",
        "category": "Markdown Pro"
      },
      {
        "command": "markdownPro.increaseFontSize",
        "title": "Increase Font Size",
        "category": "Markdown Pro"
      },
      {
        "command": "markdownPro.decreaseFontSize",
        "title": "Decrease Font Size",
        "category": "Markdown Pro"
      },
      {
        "command": "markdownPro.resetFontSize",
        "title": "Reset Font Size",
        "category": "Markdown Pro"
      },
      {
        "command": "markdownPro.search",
        "title": "Find in Document",
        "category": "Markdown Pro",
        "icon": "$(search)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "markdownPro.openEditor",
          "when": "resourceLangId =~ /^(markdown|prompt|instructions|chatagent|skill)$/",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "markdownPro.openEditor",
          "when": "resourceLangId =~ /^(markdown|prompt|instructions|chatagent|skill)$/",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "markdownPro.openEditor",
          "when": "resourceLangId =~ /^(markdown|prompt|instructions|chatagent|skill)$/"
        }
      ],
      "editor/context": [
        {
          "command": "markdownPro.openEditor",
          "when": "resourceLangId =~ /^(markdown|prompt|instructions|chatagent|skill)$/",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "markdownPro.openEditor"
        },
        {
          "command": "markdownPro.changeTheme"
        },
        {
          "command": "markdownPro.increaseFontSize"
        },
        {
          "command": "markdownPro.decreaseFontSize"
        },
        {
          "command": "markdownPro.resetFontSize"
        },
        {
          "command": "markdownPro.search",
          "when": "activeCustomEditorId == 'markdownPro.editor'"
        }
      ]
    },
    "configuration": {
      "title": "Markdown Pro",
      "properties": {
        "markdownPro.theme": {
          "type": "string",
          "default": "vscode",
          "enum": [
            "vscode",
            "github-light",
            "github-dark",
            "dracula",
            "nord",
            "solarized-light",
            "solarized-dark",
            "one-dark",
            "tokyo-night",
            "gruvbox-light",
            "gruvbox-dark",
            "catppuccin-mocha",
            "catppuccin-latte",
            "rose-pine",
            "rose-pine-dawn",
            "monokai-pro",
            "everforest-dark"
          ],
          "enumItemLabels": [
            "VS Code (match editor theme)",
            "GitHub Light",
            "GitHub Dark",
            "Dracula",
            "Nord",
            "Solarized Light",
            "Solarized Dark",
            "One Dark",
            "Tokyo Night",
            "Gruvbox Light",
            "Gruvbox Dark",
            "Catppuccin Mocha",
            "Catppuccin Latte",
            "Rosé Pine",
            "Rosé Pine Dawn",
            "Monokai Pro",
            "Everforest Dark"
          ],
          "markdownDescription": "Color theme for the Markdown Pro WYSIWYG editor. Select `VS Code` to inherit your current editor theme, or choose a standalone theme."
        },
        "markdownPro.fontSize": {
          "type": "number",
          "default": 14,
          "minimum": 8,
          "maximum": 40,
          "markdownDescription": "Font size (in pixels) for the Markdown Pro editor. Use the commands `Markdown Pro: Increase Font Size` / `Decrease Font Size` for quick adjustments."
        },
        "markdownPro.lineHeight": {
          "type": "number",
          "default": 1.6,
          "minimum": 1,
          "maximum": 3,
          "markdownDescription": "Line height (line spacing) for the Markdown Pro editor. Values like `1.4` for compact, `1.6` for normal, or `2.0` for relaxed spacing."
        },
        "markdownPro.fontFamily": {
          "type": "string",
          "default": "default",
          "enum": [
            "default",
            "serif",
            "sans-serif",
            "monospace"
          ],
          "enumItemLabels": [
            "Default (VS Code font)",
            "Serif (Georgia, Times)",
            "Sans-Serif (system UI)",
            "Monospace (editor font)"
          ],
          "markdownDescription": "Font family for the Markdown Pro editor content. Choose a preset or edit `settings.json` directly to use any CSS font-family value."
        },
        "markdownPro.contentWidth": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 1600,
          "markdownDescription": "Maximum content width (in pixels) for the Markdown Pro editor. Use `0` for full width (like the built-in VS Code markdown preview), or set a value like `900` for comfortable reading."
        },
        "markdownPro.showToolbar": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Show or hide the formatting toolbar at the top of the Markdown Pro editor."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "vscode:prepublish": "node esbuild.config.mjs --production",
    "package": "npx @vscode/vsce package"
  },
  "dependencies": {
    "@milkdown/core": "^7.18.0",
    "@milkdown/crepe": "^7.18.0",
    "@milkdown/ctx": "^7.18.0",
    "mermaid": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
