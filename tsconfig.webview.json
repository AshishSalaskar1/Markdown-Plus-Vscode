{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "rootDir": "webview",
    "moduleResolution": "bundler",
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": ["webview/**/*.ts"],
  "exclude": ["node_modules", "dist", "src"]
}
